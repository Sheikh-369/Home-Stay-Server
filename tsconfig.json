{
  "compilerOptions": {
    "noEmitOnError": false,
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,

    // ✅ Required for sequelize-typescript decorators
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
